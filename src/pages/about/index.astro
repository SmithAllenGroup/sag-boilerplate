<!-- TODO: Replace brand copy -->
---
import Layout from '../../layouts/Layout.astro';
import PageTitle from '../../sections/PageTitle.tsx';
import SharedForm from '../../components/forms/SharedForm.tsx';
import Team from '../../sections/Team.tsx';
import { site } from '../../config/site';

// SEO Title: 58 chars
const seoTitle = "About Smith Allen Group | San Diego Restaurant Brokers";

// SEO Description: 156 chars
const seoDescription = "San Diego business brokers specializing in restaurant sales. Direct access to experienced brokers who guide you through every step of selling your business.";

const meta = {
    title: "About Us",
    seo_title: seoTitle,
    seo_description: seoDescription,
    sub_title: "Experienced brokers helping restaurant owners navigate successful business sales.",
    seo_image: "/images/marketing/about-us.webp",
    url: `${site.url}/about`,
    image: "/images/marketing/about-us.webp"
};

---

<Layout {...meta}>
    <PageTitle title={meta.title} sub_title={meta.sub_title} image={meta.image} />

    <section class="container max-w-7xl py-12">
        <div class="flex flex-col lg:flex-row lg:items-start lg:gap-x-20">

            <!-- Content (Left) -->
            <div class="lg:w-2/3">
                <h2>Your Business Deserves More Than a Transaction</h2>
                <p>Selling a restaurant is personal. You've built something real—early mornings, late nights, relationships with regulars who became friends. When it's time to move on, you need someone who understands what's at stake.</p>
                <p>At Smith Allen Group, we work with restaurant owners throughout San Diego and Southern California. We handle the complexity—pricing, negotiations, due diligence, escrow—so you can focus on running your business until the keys change hands.</p>
                <p>We're not a call center. When you reach out, you talk to the people doing the work. We keep our client list intentionally small because every deal deserves real attention, not a templated process.</p>

                <h3>What We Actually Do</h3>
                <p>We represent restaurant and hospitality business owners who are ready to sell. That means honest broker price opinions based on actual market data, targeted outreach to qualified buyers, and guidance through every step from listing to close. We also work with buyers looking to acquire—matching the right people with the right opportunities.</p>

                <div class="mt-8">
                    <Team columns={2} client:load />
                </div>
            </div>

            <!-- Form (Right) -->
            <div class="mt-12 lg:mt-0 lg:w-1/3">
                <SharedForm client:load />
            </div>

        </div>
    </section>
</Layout>