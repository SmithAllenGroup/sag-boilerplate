---
import InsightLayout from '../../layouts/InsightLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
    const allInsights = await getCollection('insights', ({ data }) => import.meta.env.PROD ? !data.draft : true);
    const toSlug = (id: string) => id.replace(/\.md$/, '');

    const insights = allInsights.sort((a, b) =>
        new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
    );

    return insights.map((post) => ({
        params: { slug: toSlug(post.id) },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const wordCount = post.body ? post.body.split(/\s+/).filter(Boolean).length : undefined;
---

<InsightLayout
    title={post.data.title}
    seo_title={post.data.seo_title || post.data.title}
    seo_description={post.data.seo_description}
    pubDate={post.data.pubDate.toISOString()}
    author={post.data.author}
    category={post.data.category}
    featured_image={post.data.featured_image}
    tags={post.data.tags}
    businesses_mentioned={post.data.businesses_mentioned}
    neighborhood={post.data.neighborhood}
    read_time={post.data.read_time}
    wordCount={wordCount}
>
    <Content />
</InsightLayout>
