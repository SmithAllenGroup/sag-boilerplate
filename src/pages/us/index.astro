---
import Layout from '../../layouts/Layout.astro';
import SiloPageTitle from '../../sections/SiloPageTitle.tsx';
import SidebarCalculatorAd from '../../components/SidebarCalculatorAd.tsx';
import { site } from '../../config/site';

const meta = {
    title: `Restaurant & Business Brokerage — California and Nationwide`,
    sub_title: `Confidential brokerage services for restaurant and F&B business owners across Southern California, with alliance partners in New England, New York, and Florida.`,
    seo_title: `Restaurant Business Broker — California & Nationwide | Smith Allen Group`,
    seo_description: `Buy or sell a restaurant, cafe, or food business with Smith Allen Group. Confidential brokerage in San Diego, Orange County, LA, and nationwide through our alliance network.`,
    seo_image: `/images/silos/restaurant-dark-exterior.webp`,
    url: `${site.url}/us`,
    image: `/images/silos/restaurant-dark-exterior.webp`
};

const locations = [
    { href: "/us/ca/orange-county", label: "Orange County Business Broker" },
    { href: "/us/ca/los-angeles/sell-my-restaurant", label: "Sell Your Los Angeles Restaurant" },
    { href: "/us/ca/oxnard/business-broker", label: "Oxnard Business Broker" },
    { href: "/us/ca/escondido/business-broker", label: "Escondido Business Broker" },
    { href: "/us/ca/thousand-oaks/business-broker", label: "Thousand Oaks Business Broker" },
    { href: "/us/ca/chula-vista/sell-my-cafe", label: "Sell Your Chula Vista Cafe" },
    { href: "/us/ca/simi-valley/business-broker", label: "Simi Valley Business Broker" },
];
---

<Layout {...meta}>
    <SiloPageTitle title={meta.title} sub_title={meta.sub_title} image={meta.image} client:load/>

    <section id="silo" class="container max-w-7xl py-12">
        <div class="flex flex-col lg:flex-row lg:items-start lg:gap-x-20">

            <!-- Content (Left) -->
            <div class="lg:w-2/3">
                <h2 class="m-0">Buy or Sell a Restaurant — Expert Brokerage Across California and Beyond</h2>
                <p>Smith Allen Group specializes in the confidential sale of restaurants, cafes, bars, bakeries, and food service businesses throughout Southern California — including San Diego, Orange County, Los Angeles, and the Inland Empire. We handle everything from initial valuation to buyer qualification, negotiation, and closing.</p>
                <p>Our portfolio spans quick-service and full-service restaurants, coffee shops, juice bars, catering operations, and specialty food retailers. Whether you're an owner planning an exit or a buyer searching for the right opportunity, we bring deep industry knowledge and a network of qualified, pre-screened contacts.</p>
                <p>Through our strategic alliance with Corbett Restaurant Group, we extend our services to clients in New England, New York, and Florida — offering expert representation for business sales, lease negotiations, and tenant placement in key East Coast markets.</p>
            </div>

            <!-- Sidebar (Right) -->
            <div class="lg:mt-0 lg:w-1/3 space-y-3">
                <SidebarCalculatorAd client:load />
                <h5 class="mt-2 mb-0">Locations We Serve</h5>
                <div>
                    <ul>
                        {locations.map(({ href, label }) => (
                            <li>
                                <a href={href} title={label}>
                                    {label}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>
    </section>
</Layout>
