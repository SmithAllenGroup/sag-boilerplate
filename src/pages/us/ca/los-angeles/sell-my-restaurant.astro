---
import Layout from '../../../../layouts/Layout.astro';
import SiloPageTitle from '../../../../sections/SiloPageTitle.tsx';
import SidebarCalculatorAd from '../../../../components/SidebarCalculatorAd.tsx';
import { generateSchema } from '../../../../utils/generateSchema.js';
import { site } from '../../../../config/site';

const cityName = "Los Angeles";
const stateName = "California";
const state = "ca";
const countyName = "Los Angeles";
const cityZipCodes = "90001, 90002, 90003, 90004, 90005, 90006, 90007, 90008, 90010, 90011, 90012, 90013, 90014, 90015, 90016, 90017, 90018, 90019, 90020, 90021, 90022, 90023, 90024, 90025, 90026, 90027, 90028, 90029, 90031, 90032, 90033, 90034, 90035, 90036, 90037, 90038, 90039, 90040, 90041, 90042, 90043, 90044, 90045, 90046, 90047, 90048, 90049, 90056, 90057, 90058, 90059, 90061, 90062, 90063, 90064, 90065, 90066, 90067, 90068, 90069, 90071, 90077, 90079, 90089, 90094, 90095, 90096, 90099, 90189, 90291, 90292, 90293, 90402, 90710, 90731, 90732, 90744, 90745, 90746, 90747, 90748, 90749";
const cityWebsite = "https://www.lacity.org";
const mapQuery = encodeURIComponent(`${cityName}, ${stateName}`);

const meta = {
    title: "Sell Your Los Angeles Restaurant With Confidence",
    sub_title: "We help Los Angeles restaurant owners navigate the sale process from pricing to closing — confidentially and professionally.",
    seo_title: "Sell Your Los Angeles Restaurant | Smith Allen Group",
    seo_description: "Ready to sell your Los Angeles restaurant? Smith Allen Group provides confidential brokerage services including pricing, buyer screening, negotiation, and closing support.",
    seo_image: `/images/silos/restaurant-dark-exterior.webp`,
    url: `${site.url}/us/ca/los-angeles/sell-my-restaurant`,
    image: `/images/silos/restaurant-dark-exterior.webp`
};
---

<Layout {...meta}>
    <script type="application/ld+json" slot="head" set:html={JSON.stringify(generateSchema({ service: "Restaurant Seller Representation", cityName, stateName, state, url: meta.url }))} />
    <SiloPageTitle title={meta.title} sub_title={meta.sub_title} image={meta.image} client:load/>

    <section id="silo" class="container max-w-7xl py-12">
        <div class="flex flex-col lg:flex-row lg:items-start lg:gap-x-20">

            <!-- Content (Left) -->
            <div class="lg:w-2/3">
                <h2 class="m-0">Confidentially Selling Los Angeles Restaurants</h2>
                <p>Smith Allen Group is a trusted business brokerage and commercial real estate firm specializing in the sale and leasing of restaurants throughout Los Angeles. Our deep industry knowledge and hands-on experience with restaurant deals make us a proven partner for owners, buyers, and operators at every stage of the business cycle. We work with businesses of all sizes — from single-unit independents to multi-unit operators — offering tailored services that include broker price opinions, market analysis, targeted marketing, lease negotiations, and end-to-end transaction management.</p>

                <p>Our commitment to confidentiality, professionalism, and successful outcomes has earned us a strong reputation in Los Angeles and across California. Whether you're preparing for your first acquisition or planning an exit strategy, Smith Allen Group offers the expertise and support needed to close with confidence. Let our team guide you through the complexities of selling your restaurant in Los Angeles.</p>

                <p>Through our strategic alliance with Corbett Restaurant Group, we extend our reach to clients in New England, New York, and Florida — providing expert representation for business sales, lease negotiations, and tenant placement opportunities along the East Coast.</p>

                <h3>Why Sell Your Restaurant With Smith Allen Group</h3>
                <ul class="list-disc pl-6 space-y-1 pt-4">
                    <li><strong>Accurate Pricing</strong> using financial analysis, normalized earnings, and industry multiples to set a competitive and defensible price.</li>
                    <li><strong>Confidential Marketing</strong> that targets qualified buyers while protecting your identity and maintaining operations.</li>
                    <li><strong>Buyer Screening</strong> to verify financial capacity, fit, and intent before sharing sensitive details.</li>
                    <li><strong>Negotiation & Deal Structure</strong> to optimize price, terms, risk allocation, and timeline.</li>
                    <li><strong>Due Diligence & Closing Support</strong> coordinating documents, advisors, and milestones through signing and close.</li>
                </ul>

                <h3>Our Process</h3>
                <ol class="list-decimal pl-6 space-y-1 pt-4">
                    <li><strong>Discovery & Readiness</strong> — clarify goals, gather financials, and outline strategy.</li>
                    <li><strong>Broker Price Opinion</strong> — apply multiples, DCF, and market comps to determine a range and listing strategy.</li>
                    <li><strong>Confidential Offering</strong> — prepare a Confidential Information Memorandum, launch discreet outreach, and manage inquiries.</li>
                    <li><strong>Buyer Vetting</strong> — qualify buyers, coordinate Q&A, and solicit offers.</li>
                    <li><strong>Negotiation</strong> — align on price, terms, earn-outs, and transition plans.</li>
                    <li><strong>Due Diligence & Closing</strong> — coordinate advisors, resolve issues, and close the transaction.</li>
                </ol>

                <p>Ready to explore your options? <a href="/contact">Request a confidential consultation</a> and we'll outline a clear path to maximizing the value of your Los Angeles restaurant.</p>
            </div>

            <div class="lg:mt-0 lg:w-1/3 space-y-3">
                <SidebarCalculatorAd client:load />
                <div>
                    <iframe
                        width="100%"
                        height="300"
                        style="border:0"
                        loading="lazy"
                        allowfullscreen
                        referrerpolicy="no-referrer-when-downgrade"
                        src={`https://maps.google.com/maps?q=${mapQuery}&output=embed`}>
                    </iframe>
                </div>
                <h5 class="pt-3 mb-0">City of {cityName} Information</h5>
                <h6 class="font-medium mt-3 mb-0">County</h6>
                <div class="!m-0">{countyName}</div>
                <h6 class="font-medium mt-3 mb-0">{cityName} City Website</h6>
                <div class="!m-0">
                    <a href={cityWebsite} title={`City of ${cityName}`} target="_blank">
                        City of {cityName}
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
