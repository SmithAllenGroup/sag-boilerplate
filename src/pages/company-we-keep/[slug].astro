---
import Layout from '../../layouts/Layout.astro';
import PageTitle from '../../sections/PageTitle.tsx';
import { getCollection, render } from 'astro:content';
import { Globe, Phone, Mail, MapPin, User } from 'lucide-react';
import { site } from '../../config/site';

export async function getStaticPaths() {
    // Filter out drafts from static generation
    const posts = await getCollection('company-we-keep', ({ data }) => !data.draft);
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const meta = {
    title: post.data.title,
    seo_title: post.data.seo_title || `${post.data.title} | The Company We Keep | ${site.name}`,
    seo_description: post.data.seo_description || post.data.summary,
    seo_image: post.data.seo_image || post.data.image || "/images/marketing/company_we_keep_social.webp",
    url: `${site.url}/company-we-keep/${post.slug}`,
    image: post.data.image || "/images/marketing/company_we_keep.webp",
    pubDate: post.data.pubDate,
    updatedDate: post.data.updatedDate,
    author: post.data.author,
    isArticle: true,
};

// Filter h2 headings for the chapter sidebar
const markdownChapters = headings.filter((h) => h.depth === 2);

// Create "About {title}" as the first chapter entry
const aboutSlug = `about-${post.data.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;
const chapters = [
    { depth: 2, slug: aboutSlug, text: `About ${post.data.title}` },
    ...markdownChapters,
];

// Check if we have any partner info to display
const hasPartnerInfo = post.data.partner_url || post.data.partner_phone ||
    post.data.partner_email || post.data.partner_contact || post.data.partner_address;
const hasPartnerLogo = post.data.partner_logo;
const hasSidebar = hasPartnerLogo || hasPartnerInfo || chapters.length > 0;

// Format address if exists
const formatAddress = (address: typeof post.data.partner_address) => {
    if (!address) return null;
    const parts = [
        address.street,
        address.street2,
        [address.city, address.state].filter(Boolean).join(', '),
        address.zip,
    ].filter(Boolean);
    return parts;
};
---

<Layout {...meta}>
    <PageTitle title={post.data.title} sub_title={post.data.summary} image={meta.image} />

    <!-- Content -->
    <section class="container py-12">
        <div class="relative mx-auto w-full max-w-5xl items-start justify-between gap-20 lg:flex">
            <!-- Sidebar -->
            {hasSidebar && (
                <div class="top-20 flex-1 bg-background pb-10 lg:sticky lg:pb-0 space-y-5">
                    <!-- Partner Logo -->
                    {hasPartnerLogo && (
                        <div class="mb-6">
                            {post.data.partner_url ? (
                                <a href={post.data.partner_url} target="_blank" rel="noopener noreferrer" class="block">
                                    <img
                                        src={post.data.partner_logo}
                                        alt={`${post.data.title} logo`}
                                        class="max-w-full h-auto max-h-24 object-contain"
                                    />
                                </a>
                            ) : (
                                <img
                                    src={post.data.partner_logo}
                                    alt={`${post.data.title} logo`}
                                    class="max-w-full h-auto max-h-24 object-contain"
                                />
                            )}
                        </div>
                    )}

                    <!-- Partner Contact Info -->
                    {hasPartnerInfo && (
                        <div class="space-y-4">
                            <div class="text-lg font-semibold">Contact Information</div>

                            <!-- Contact Person with Photo -->
                            {post.data.partner_contact && (
                                <div class="flex items-center gap-3">
                                    {post.data.partner_contact_photo ? (
                                        <img
                                            src={post.data.partner_contact_photo}
                                            alt={post.data.partner_contact}
                                            class="w-10 h-10 rounded-full object-cover"
                                        />
                                    ) : (
                                        <div class="w-10 h-10 rounded-full bg-muted flex items-center justify-center">
                                            <User className="w-5 h-5 text-muted-foreground" />
                                        </div>
                                    )}
                                    <span class="text-[15px] font-medium">{post.data.partner_contact}</span>
                                </div>
                            )}

                            <!-- Website -->
                            {post.data.partner_url && (
                                <a
                                    href={post.data.partner_url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-2 text-[15px] text-muted-foreground hover:text-foreground transition-colors"
                                >
                                    <Globe className="w-[18px] h-[18px] flex-shrink-0" />
                                    <span class="truncate">{new URL(post.data.partner_url).hostname}</span>
                                </a>
                            )}

                            <!-- Phone -->
                            {post.data.partner_phone && (
                                <a
                                    href={`tel:${post.data.partner_phone.replace(/\D/g, '')}`}
                                    class="flex items-center gap-2 text-[15px] text-muted-foreground hover:text-foreground transition-colors"
                                >
                                    <Phone className="w-[18px] h-[18px] flex-shrink-0" />
                                    <span>{post.data.partner_phone}</span>
                                </a>
                            )}

                            <!-- Email -->
                            {post.data.partner_email && (
                                <a
                                    href={`mailto:${post.data.partner_email}`}
                                    class="flex items-center gap-2 text-[15px] text-muted-foreground hover:text-foreground transition-colors"
                                >
                                    <Mail className="w-[18px] h-[18px] flex-shrink-0" />
                                    <span class="truncate">{post.data.partner_email}</span>
                                </a>
                            )}

                            <!-- Address -->
                            {post.data.partner_address && formatAddress(post.data.partner_address) && (
                                <div class="flex items-start gap-2 text-[15px] text-muted-foreground">
                                    <MapPin className="w-[18px] h-[18px] flex-shrink-0 mt-0.5" />
                                    <div class="flex flex-col">
                                        {formatAddress(post.data.partner_address)?.map((line) => (
                                            <span>{line}</span>
                                        ))}
                                    </div>
                                </div>
                            )}
                        </div>
                    )}

                    <!-- Chapters Navigation -->
                    {chapters.length > 0 && (
                        <div>
                            <div class="text-lg font-semibold">Chapters</div>
                            <nav id="chapters-nav" class="flex flex-col gap-2 pt-2 pl-2">
                                {chapters.map((chapter) => (
                                    <a
                                        href={`#${chapter.slug}`}
                                        data-chapter={chapter.slug}
                                        class="chapter-link block text-[15px] leading-normal font-medium text-muted-foreground transition duration-300 hover:text-primary"
                                    >
                                        {chapter.text}
                                    </a>
                                ))}
                            </nav>
                        </div>
                    )}

                    <!-- Partner Badges/Certifications -->
                    {post.data.partner_badges && post.data.partner_badges.filter(b => b.image).length > 0 && (
                        <div class="flex flex-wrap gap-4 pt-4">
                            {post.data.partner_badges.filter(b => b.image).map((badge) => (
                                badge.url ? (
                                    <a href={badge.url} target="_blank" rel="noopener noreferrer" class="block">
                                        <img
                                            src={badge.image}
                                            alt={badge.alt || 'Partner badge'}
                                            class="h-16 w-auto object-contain"
                                        />
                                    </a>
                                ) : (
                                    <img
                                        src={badge.image}
                                        alt={badge.alt || 'Partner badge'}
                                        class="h-16 w-auto object-contain"
                                    />
                                )
                            ))}
                        </div>
                    )}
                </div>
            )}

            <!-- Main Content -->
            <div class={`flex w-full flex-col gap-10 ${hasSidebar ? 'max-w-[40rem]' : 'max-w-3xl mx-auto'}`}>
                <div class="partner-content max-w-none [&_h2]:scroll-mt-24 [&_h3]:scroll-mt-24">
                    <h2 id={aboutSlug} class="mt-0">About {post.data.title}</h2>
                    <Content />
                </div>

                <!-- Back to list -->
                <div class="pt-8 border-t border-gray-200">
                    <a
                        href="/company-we-keep/"
                        class="inline-flex items-center text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
                    >
                        <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                        Back to The Company We Keep
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .chapter-link.active {
        color: var(--primary);
        font-weight: 600;
        background-color: var(--muted);
        border-radius: 0.375rem;
        padding: 0.25rem 0.5rem;
        margin-left: -0.5rem;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const chapterLinks = document.querySelectorAll('.chapter-link');
        if (chapterLinks.length === 0) return;

        // Get all section IDs from the chapter links
        const sectionIds = Array.from(chapterLinks).map(link =>
            link.getAttribute('data-chapter')
        ).filter(Boolean);

        // Get corresponding heading elements
        const headings = sectionIds
            .map(id => document.getElementById(id!))
            .filter(Boolean) as HTMLElement[];

        if (headings.length === 0) return;

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        // Remove active class from all links
                        chapterLinks.forEach(link => link.classList.remove('active'));

                        // Add active class to the corresponding link
                        const activeLink = document.querySelector(
                            `.chapter-link[data-chapter="${entry.target.id}"]`
                        );
                        if (activeLink) {
                            activeLink.classList.add('active');
                        }
                    }
                });
            },
            {
                rootMargin: '-20% 0px -60% 0px',
                threshold: 0
            }
        );

        headings.forEach(heading => observer.observe(heading));
    });
</script>
