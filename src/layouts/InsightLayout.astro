---
import Layout from './Layout.astro';
import { site } from '../config/site';

interface Props {
    title: string;
    seo_title?: string;
    seo_description?: string;
    author?: string;
    pubDate: string;
    category: 'market-spotlight' | 'market-report' | 'news-analysis';
    featured_image?: string;
    tags?: string[];
    businesses_mentioned?: string[];
    neighborhood?: string;
    read_time?: number;
    wordCount?: number;
}

const {
    title,
    seo_title,
    seo_description,
    author = site.business.founder.name,
    pubDate,
    category,
    featured_image,
    tags,
    businesses_mentioned,
    neighborhood,
    read_time,
    wordCount,
} = Astro.props;

const url = `${site.url}${Astro.url.pathname}`;

const meta = {
    title,
    seo_title: seo_title || title,
    seo_description,
    seo_image: featured_image,
    url,
    pubDate: new Date(pubDate),
    author,
    isArticle: false,
};

const categoryConfig = {
    'market-spotlight': { label: 'Market Spotlight', color: 'bg-amber-100 text-amber-800' },
    'market-report': { label: 'Market Report', color: 'bg-blue-100 text-blue-800' },
    'news-analysis': { label: 'News Analysis', color: 'bg-green-100 text-green-800' },
};

const cat = categoryConfig[category];

// Append T12:00:00 to date-only strings to prevent timezone rollback
const safeDate = typeof pubDate === 'string' && !pubDate.includes('T')
    ? new Date(pubDate + 'T12:00:00')
    : new Date(pubDate);
const formattedDate = safeDate.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
});

// NewsArticle schema
const newsArticleSchema = {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "@id": `${url}#article`,
    "headline": seo_title || title,
    "name": title,
    "description": seo_description,
    "url": url,
    ...(featured_image ? { "image": { "@type": "ImageObject", "url": featured_image, "width": "1200", "height": "630" } } : {}),
    "datePublished": safeDate.toISOString(),
    "dateModified": safeDate.toISOString(),
    "author": {
        "@type": "Person",
        "@id": `${site.url}/#${site.business.founder.slug}`,
        "name": author,
        "url": `${site.url}/about/${site.business.founder.slug}`
    },
    "publisher": {
        "@type": "Organization",
        "@id": `${site.url}/#organization`,
        "name": site.name,
        "logo": { "@type": "ImageObject", "url": `${site.url}${site.brand.logoPng}`, "width": site.brand.logoSchemaWidth, "height": site.brand.logoSchemaHeight }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": url },
    "articleSection": "Market Analysis",
    "keywords": tags?.length ? tags.join(", ") : "restaurant market, San Diego, business brokerage",
    ...(wordCount ? { "wordCount": wordCount } : {}),
    "inLanguage": "en-US",
    ...(neighborhood ? { "about": [{ "@type": "Place", "name": `${neighborhood}, San Diego` }] } : {}),
};
---

<Layout {...meta}>
    <script type="application/ld+json" slot="head" set:html={JSON.stringify(newsArticleSchema)} />

    <!-- Insight Header -->
    <header>
        <div class="max-w-4xl mx-auto px-6 sm:px-12 py-10">
            <div class="flex items-center gap-3 mb-4 text-sm">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${cat.color}`}>
                    {cat.label}
                </span>
                {neighborhood && (
                    <span class="text-gray-500">{neighborhood}</span>
                )}
            </div>
            <h1 class="text-3xl sm:text-5xl font-lora font-bold text-gray-900 mb-4">{title}</h1>
            <div class="flex items-center gap-4 text-sm text-gray-500">
                <span>By {author}</span>
                <span class="text-gray-300">|</span>
                <time datetime={safeDate.toISOString()}>{formattedDate}</time>
                {read_time && (
                    <>
                        <span class="text-gray-300">|</span>
                        <span>{read_time} min read</span>
                    </>
                )}
            </div>
        </div>
    </header>

    {featured_image && (
        <div class="max-w-4xl mx-auto px-6 sm:px-12 -mb-4">
            <img src={featured_image} alt={title} class="w-full rounded-lg shadow-md" />
        </div>
    )}

    <!-- Article Body -->
    <article class="max-w-3xl mx-auto py-12 px-6 sm:px-12">
        <slot />

        <!-- Businesses Mentioned -->
        {businesses_mentioned && businesses_mentioned.length > 0 && (
            <div class="mt-10 pt-6 border-t border-gray-200">
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">Businesses Mentioned</p>
                <div class="flex flex-wrap gap-2">
                    {businesses_mentioned.map(biz => (
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs bg-gray-100 text-gray-600">
                            {biz}
                        </span>
                    ))}
                </div>
            </div>
        )}

        <!-- Tags -->
        {tags && tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
                {tags.map(tag => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-gray-50 text-gray-500 border border-gray-200">
                        {tag}
                    </span>
                ))}
            </div>
        )}

        <!-- Soft CTA -->
        <aside class="mt-6 p-6 bg-gray-50 rounded-lg border border-gray-200">
            <p class="text-gray-700 text-sm leading-relaxed mt-0">
                {site.name} tracks market trends across Southern California. If you're curious about your business's position in the current market, <a href="/contact" class="text-blue-600 hover:text-blue-800 underline">start a confidential conversation</a>.
            </p>
            <p class="text-gray-700 text-sm leading-relaxed">
                Thinking about what your restaurant could be worth? Our free <a href="/resources/calculators/sde-calculator" class="text-blue-600 hover:text-blue-800 underline">SDE Calculator</a> gives you an instant estimate based on current multiples.
            </p>
        </aside>
    </article>
</Layout>
